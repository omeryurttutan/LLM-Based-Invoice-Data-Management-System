# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=fatura_user
POSTGRES_PASSWORD=fatura_secret_2026
POSTGRES_DB=fatura_ocr_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2026

# ==========================================
# RabbitMQ Configuration
# ==========================================
RABBITMQ_USER=fatura_mq
RABBITMQ_PASSWORD=mq_secret_2026
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ==========================================
# Backend Configuration (Spring Boot)
# ==========================================
# Profiles: dev, staging, prod
SPRING_PROFILES_ACTIVE=prod
# Encryption Key for KVKK (AES-256) - Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_warning_change_this
# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_must_be_very_long
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@faturaocr.com

# ==========================================
# Frontend Configuration (Next.js)
# ==========================================
# URL of the backend API (browser access)
NEXT_PUBLIC_API_URL=https://fatura-ocr.com/api/v1
# URL of the WebSocket (browser access)
NEXT_PUBLIC_WS_URL=wss://fatura-ocr.com/ws
# Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
# Environment: development, staging, production
NEXT_PUBLIC_APP_ENV=production

# ==========================================
# Extraction Service Configuration (Python)
# ==========================================
# API Keys (Required)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
# Server Settings
LOG_LEVEL=info
UVICORN_WORKERS=4

# ==========================================
# Docker Compose Settings
# ==========================================
# Backup Directory
BACKUP_DIR=./backups
